{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "src/main",
  "compilerOptions": {
    "deleteOutDir": true,
    "plugins": [],
    "watchAssets": true
  },
  "watchOptions": {
    "usePolling": true,
    "interval": 1000,
    "ignored": ["**/node_modules/**", "**/dist/**"]
  }
}
